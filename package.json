{
  "name": "@denizhosgor/pagespeedinsight-mcp",
  "version": "0.1.9",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "description": "MCP server for Google PageSpeed Insights",
  "type": "module",
  "main": "src/server.js",
  "bin": {
    "pagespeedinsight-mcp": "bin/pagespeedinsight-mcp.js"
  },
  "files": [
    "bin",
    "src",
    "scripts",
    "skills",
    "docs",
    "README.md",
    "README.tr.md",
    "LICENSE"
  ],
  "scripts": {
    "postinstall": "node scripts/install-skill.js --auto",
    "start": "node bin/pagespeedinsight-mcp.js",
    "install-skill": "node scripts/install-skill.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "node --check src/core/pagespeed.js && node --check src/server.js && node --check src/paperclip-worker.js && node --check bin/pagespeedinsight-mcp.js && node --check scripts/install-skill.js && npm run test",
    "security:prod": "npm_config_cache=.npm-cache npm audit --omit=dev --audit-level=high",
    "security:full": "npm_config_cache=.npm-cache npm audit --audit-level=moderate",
    "pack:dry-run": "npm_config_cache=.npm-cache npm pack --dry-run",
    "release:check": "npm run check && npm run security:prod && npm run pack:dry-run"
  },
  "keywords": [
    "mcp",
    "pagespeed",
    "pagespeed-insights",
    "lighthouse",
    "openclaw"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20 <25"
  },
  "paperclip": {
    "id": "pagespeedinsight-mcp",
    "apiVersion": "1",
    "capabilities": [
      "agent.tools.register",
      "http.outbound"
    ],
    "entrypoints": {
      "worker": "src/paperclip-worker.js"
    },
    "tools": [
      {
        "name": "run_pagespeed",
        "displayName": "Run PageSpeed Insights",
        "description": "Generate full PageSpeed reports for a page.",
        "parametersSchema": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "url"
          ],
          "properties": {
            "url": {
              "type": "string",
              "minLength": 1
            },
            "strategy": {
              "type": "string",
              "enum": [
                "mobile",
                "desktop"
              ],
              "default": "desktop"
            },
            "categories": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "locale": {
              "type": "string",
              "default": "en-US"
            },
            "timeout_seconds": {
              "type": "integer",
              "minimum": 5,
              "maximum": 180,
              "default": 60
            },
            "include_raw": {
              "type": "boolean",
              "default": false
            },
            "utm_campaign": {
              "type": "string"
            },
            "utm_source": {
              "type": "string"
            },
            "captcha_token": {
              "type": "string"
            }
          }
        }
      },
      {
        "name": "compare_pagespeed",
        "displayName": "Compare PageSpeed Insights",
        "description": "Compare mobile and desktop PageSpeed reports for the same URL.",
        "parametersSchema": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "url"
          ],
          "properties": {
            "url": {
              "type": "string",
              "minLength": 1
            },
            "categories": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "locale": {
              "type": "string",
              "default": "en-US"
            },
            "timeout_seconds": {
              "type": "integer",
              "minimum": 5,
              "maximum": 180,
              "default": 60
            },
            "utm_campaign": {
              "type": "string"
            },
            "utm_source": {
              "type": "string"
            },
            "captcha_token": {
              "type": "string"
            }
          }
        }
      }
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "vitest": "^4.0.4"
  }
}
